# ==========================================
# COOPHCCAR - Variáveis de Ambiente
# ==========================================
# Copie este arquivo para .env e preencha os valores

# Servidor
PORT=3000

# JWT (altere para um segredo forte em produção)
JWT_SECRET=coophccar-admin-secret-2025

# SMTP - Envio de e-mails (recuperação de senha)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=contato@coophccar.org.br
